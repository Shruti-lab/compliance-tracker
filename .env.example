# Compliance Tracker Configuration

# PostgreSQL Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=compliance_tracker

# IBM Cloud Configuration
IBM_CLOUD_API_KEY=your_ibm_api_key_here
IBM_CLOUD_ACCOUNT_ID=your_account_id_here
IBM_CLOUD_REGION=us-south

# Groq API Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Polling Configuration
POLL_INTERVAL_SECONDS=60
WORKFLOW_INTERVAL_SECONDS=120

# Logging Configuration
LOG_LEVEL=INFO
LOG_DIR=logs

# Output Configuration
OUTPUT_DIR=output

# Vector Store Configuration
CHROMA_PERSIST_DIR=src/vectorstore/chroma_data
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Compliance Documents
COMPLIANCE_DOCS_DIR=compliance_docs

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false